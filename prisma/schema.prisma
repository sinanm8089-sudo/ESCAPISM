// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Memory {
  id        String   @id @default(cuid())
  src       String
  title     String
  category  String
  location  String
  date      String
  width     Int
  height    Int
  createdAt DateTime @default(now())
}
